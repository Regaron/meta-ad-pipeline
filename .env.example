# Anthropic auth - ONE of:
#   (a) logged in via `claude` CLI (OAuth to Pro/Max subscription, local dev only)
#   (b) ANTHROPIC_API_KEY (required for non-local or multi-user deployment)
#
# NOTE: the creative-director's `critique_render` tool calls the raw
# Anthropic API directly (the SDK's MCP transport drops image content
# blocks). If ANTHROPIC_API_KEY is not set, the critique tool returns a
# neutral verdict and the pipeline still works - it just can't
# vision-critique the rendered PNG.
# ANTHROPIC_API_KEY=

# Browser Use Cloud - get at https://cloud.browser-use.com
BROWSER_USE_API_KEY=bu_...

# Pipeboard Meta Ads MCP
# Obtain via: npx @modelcontextprotocol/inspector
#   -> Transport: Streamable HTTP
#   -> URL: https://meta-ads.mcp.pipeboard.co/
#   -> Open Auth Settings -> Quick OAuth Flow -> copy access_token
PIPEBOARD_OAUTH_TOKEN=

# Tigris (S3-compatible object storage)
# Get credentials at https://console.tigris.dev
TIGRIS_STORAGE_ACCESS_KEY_ID=tid_...
TIGRIS_STORAGE_SECRET_ACCESS_KEY=tsec_...
TIGRIS_STORAGE_BUCKET=ad-images-tigris

# Optional Tigris overrides - defaults shown.
# TIGRIS_API_ENDPOINT=https://t3.storage.dev
# TIGRIS_PUBLIC_HOST=t3.tigrisfiles.io

# Langfuse observability - create project at https://cloud.langfuse.com
# (US region: https://us.cloud.langfuse.com). Leave blank to disable tracing.
LANGFUSE_PUBLIC_KEY=pk-lf-...
LANGFUSE_SECRET_KEY=sk-lf-...
LANGFUSE_HOST=https://cloud.langfuse.com

# Memory: set to 1 to disable the BrandResearch scrape cache across turns.
# AD_PIPELINE_DISABLE_SCRAPE_CACHE=1

# Live integration suite
TEST_LANDING_URL=https://example.com
TEST_META_AD_ACCOUNT_ID=act_1234567890
TEST_META_PAGE_ID=1234567890
# TEST_ALLOW_ACTIVATION=1
